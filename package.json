{
  "name": "@pinta-ai/pinta-cc",
  "version": "1.5.1",
  "description": "Generic OTLP forwarder for Claude Code hook events",
  "main": "dist/index.js",
  "license": "PolyForm-Noncommercial-1.0.0",
  "files": [
    "dist",
    ".claude-plugin",
    "hooks",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/pinta-ai/pinta-cc.git"
  },
  "homepage": "https://github.com/pinta-ai/pinta-cc#readme",
  "bugs": {
    "url": "https://github.com/pinta-ai/pinta-cc/issues"
  },
  "scripts": {
    "bump": "node scripts/bump.mjs",
    "typecheck": "tsc --noEmit",
    "build": "tsc --noEmit && esbuild src/index.ts --bundle --platform=node --format=cjs --target=node18 --minify --outfile=dist/index.js",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "mock-server": "npx tsx tools/mock-server.ts",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@pinta-ai/core": "^0.3.0",
    "@types/node": "^22.0.0",
    "esbuild": "^0.24.0",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  }
}
